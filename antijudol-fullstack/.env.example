# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit file .env asli.

# ─── Database PostgreSQL ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antijudol
DB_USER=postgres
DB_PASSWORD=ganti_password_database_anda

# ─── JWT (WAJIB ganti dengan string acak panjang) ─
JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_unik

# ─── Port server ─────────────────────────────────
PORT=3001
