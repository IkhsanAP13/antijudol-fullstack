# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit file .env asli.

# ══════════════════════════════════════════════════════════════════
# BACKEND (server.js)
# ══════════════════════════════════════════════════════════════════

# --- Opsi A: Database via connection string (Neon/Railway, PRODUKSI) ---
# Jika DATABASE_URL diisi, koneksi otomatis pakai SSL & mengabaikan DB_* di bawah.
# DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Opsi B: Database lokal (DEVELOPMENT) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=antijudol
DB_USER=postgres
DB_PASSWORD=ganti_password_database_anda

# JWT (WAJIB ganti dengan string acak panjang & unik)
JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_unik

# Port server
PORT=3001

# CORS: kosongkan untuk mengizinkan semua origin (uji coba),
# atau isi URL frontend (mis. https://antijudol-fullstack.vercel.app) untuk membatasi.
# CORS_ORIGIN=https://antijudol-fullstack.vercel.app

# ══════════════════════════════════════════════════════════════════
# FRONTEND (Vite) — set di Vercel: Project Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════

# URL backend untuk dashboard. Kosong = path relatif "/api" (mode lokal).
# Produksi: arahkan ke backend Railway (TANPA garis miring di akhir).
# VITE_API_URL=https://nama-app.up.railway.app
